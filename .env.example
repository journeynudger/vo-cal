# Supabase (local dev defaults: supabase start prints these)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM (parser + why layer)
ANTHROPIC_API_KEY=
PARSER_MODEL=claude-sonnet-4-6

# Transcription
ELEVENLABS_API_KEY=

# Nutrition
USDA_FDC_API_KEY=

# API
# DEBUG=true is for LOCAL dev only. With TEST_MODE=true it enables the trusted
# X-Test-User auth seam (no JWT) — NEVER set either against a hosted database: the
# app fails-fast and refuses to boot (main._refuse_test_auth_against_hosted_db).
DEBUG=true
# TEST_MODE=false   # only the offline test suite turns this on
CORS_ORIGINS=["http://localhost:3000"]
